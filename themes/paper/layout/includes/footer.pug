- let aiPromptUrl = full_url_for(page.path || '').replace(/index\.html$/, '')
- let aiPromptTitle = page.title || ''
- let aiPrompt = ''
- if (is_post() || page._note || page._think || page._read) {
-   aiPrompt = 'Please summarize the article "' + aiPromptTitle + '": ' + aiPromptUrl
- } else {
-   aiPrompt = 'Please summarize the blog jopus.cn — what topics does the author write about and what makes it unique?'
- }
