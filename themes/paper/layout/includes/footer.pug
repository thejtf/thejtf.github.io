  .footer-ai__toast Prompt copied, paste it in the chat
  script.
    (function() {
      var container = document.querySelector('.footer-ai');
      var toast = document.querySelector('.footer-ai__toast');
      var prompt = container.getAttribute('data-prompt');
      container.addEventListener('click', function(e) {
        var btn = e.target.closest('.footer-ai__btn');
        if (!btn) return;
        e.preventDefault();
        var url = btn.getAttribute('data-url');
        var fullUrl = url + (url.indexOf('?') === -1 ? '?' : '&') + 'q=' + encodeURIComponent(prompt);
        window.open(fullUrl, '_blank');
        navigator.clipboard.writeText(prompt).then(function() {
          toast.classList.add('show');
          setTimeout(function() {
            toast.classList.remove('show');
          }, 2000);
        });
      });
    })();
