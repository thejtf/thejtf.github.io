.sidebar
  //- 默认参数 true，note/read/think 页面不显示 Toc
  if !page.posts && page.type !== 'note' && page.type !== 'read' && page.type !== 'think' && (theme.toc === undefind || theme.toc === true)
    include ./toc

  if theme.link === undefind || theme.link === true
    h2 Links
    .sidebar__link
      if theme.social
        ul
          each url,label in theme.social
            li
              a(href=url_for(url)) #{label}

  //- 判断是否为 note 相关页面
  - var _isNotePage = page.type === 'note' || page._note || page._noteCategory || page._noteTag || page._noteArchive

  //- 判断是否为 read 相关页面
  - var _isReadPage = page.type === 'read' || page._read || page._readCategory || page._readTag || page._readArchive

  //- 判断是否为 think 相关页面
  - var _isThinkPage = page.type === 'think' || page._think || page._thinkCategory || page._thinkTag || page._thinkArchive

  if theme.archives === undefind || theme.archives === true
    h2 Archives
    .sidebar__archives
      if _isNotePage
        //- note 页面只显示 notes 的归档
        if noteArchives && noteArchives.length > 0
          ul.archive-list
            each archive in noteArchives
              li.archive-list-item
                a.archive-list-link(href=url_for(archive.path)) #{archive.name}
      else if _isReadPage
        //- read 页面只显示 reads 的归档
        if readArchives && readArchives.length > 0
          ul.archive-list
            each archive in readArchives
              li.archive-list-item
                a.archive-list-link(href=url_for(archive.path)) #{archive.name}
      else if _isThinkPage
        //- think 页面只显示 thinks 的归档
        if thinkArchives && thinkArchives.length > 0
          ul.archive-list
            each archive in thinkArchives
              li.archive-list-item
                a.archive-list-link(href=url_for(archive.path)) #{archive.name}
      else
        //- 普通页面只显示 posts 的归档
        != list_archives({type:"yearly", format: "YYYY", show_count: false})

  if theme.categories === undefind || theme.categories === true
    h2 Categories
    .sidebar__categories
      if _isNotePage
        //- note 页面只显示 notes 的分类
        if noteCategories && noteCategories.length > 0
          ul.category-list
            each cat in noteCategories
              li.category-list-item
                a.category-list-link(href=url_for(cat.path)) #{cat.name}
      else if _isReadPage
        //- read 页面只显示 reads 的分类
        if readCategories && readCategories.length > 0
          ul.category-list
            each cat in readCategories
              li.category-list-item
                a.category-list-link(href=url_for(cat.path)) #{cat.name}
      else if _isThinkPage
        //- think 页面只显示 thinks 的分类
        if thinkCategories && thinkCategories.length > 0
          ul.category-list
            each cat in thinkCategories
              li.category-list-item
                a.category-list-link(href=url_for(cat.path)) #{cat.name}
      else
        //- 普通页面只显示 posts 的分类
        != list_categories({show_count: false})

  if theme.tags === undefind || theme.tags === true
    h2 Tags
    .sidebar__tags
      if _isNotePage
        //- note 页面只显示 notes 的标签
        if noteTags && noteTags.length > 0
          ul.tag-list
            each tag in noteTags
              li.tag-list-item
                a.tag-list-link(href=url_for(tag.path)) #{tag.name}
      else if _isReadPage
        //- read 页面只显示 reads 的标签
        if readTags && readTags.length > 0
          ul.tag-list
            each tag in readTags
              li.tag-list-item
                a.tag-list-link(href=url_for(tag.path)) #{tag.name}
      else if _isThinkPage
        //- think 页面只显示 thinks 的标签
        if thinkTags && thinkTags.length > 0
          ul.tag-list
            each tag in thinkTags
              li.tag-list-item
                a.tag-list-link(href=url_for(tag.path)) #{tag.name}
      else
        //- 普通页面只显示 posts 的标签
        != list_tags({show_count: false})